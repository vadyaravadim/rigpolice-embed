{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "rigpolice/embed",
	"title": "RigPolice Tool",
	"category": "embed",
	"icon": "screenoptions",
	"description": "Embed a free RigPolice gear-test tool. The widget loads in its own frame and auto-resizes.",
	"keywords": [ "rigpolice", "embed", "test", "widget", "gaming" ],
	"textdomain": "rigpolice-embed",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"attributes": {
		"tool": { "type": "string", "default": "" },
		"anchor": { "type": "string", "default": "" },
		"showcredit": { "type": "boolean", "default": false },
		"from": { "type": "string", "default": "" },
		"to": { "type": "string", "default": "" },
		"width": { "type": "number" }
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./editor.css",
	"render": "file:./render.php"
}
